# 智谱 AI 授权 Token（必填）
# 获取方式：登录 https://chatglm.cn 后，从浏览器开发者工具的 Cookie 中获取 chatglm_token 的值
# 格式：直接填写 token 值，无需 "Bearer " 前缀
ZHIPU_AUTH_TOKEN=your_chatglm_token_here

# 智谱 AI 签名密钥（一般无需修改）
ZHIPU_SIGN_SECRET=your_zhipu_sign_secret_here

# MySQL 数据库配置（使用异步驱动 aiomysql）
DATABASE_URL=mysql+aiomysql://storyloom:storyloom_password@mysql:3306/storyloom?charset=utf8mb4

# Redis 配置
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# 后端配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 视频生成配置
VIDEO_RESOLUTION=3840x2160  # 4K
VIDEO_QUALITY=quality
VIDEO_FPS=30
VIDEO_DURATION=5

# DeepSeek API 配置（用于 Prompt 优化）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Google Gemini 图片生成（中转站）
GEMINI_API_KEY=your_gemini_api_key_here
